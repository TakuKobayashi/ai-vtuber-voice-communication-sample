{
  "name": "ai-vtuber-voice-communication-sample-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev:web": "pnpm --filter ai-vtuber-voice-communication-sample-web dev",
    "dev:server": "pnpm --filter ai-vtuber-voice-communication-sample-web build && pnpm --filter ai-vtuber-voice-communication-sample-server dev",
    "build:web": "pnpm --filter ai-vtuber-voice-communication-sample-web build",
    "deploy:cloudflare": "pnpm build:web && pnpm --filter ai-vtuber-voice-communication-sample-server deploy:cloudflare",
    "lint": "pnpm --filter ai-vtuber-voice-communication-sample-web lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
